{
    "semi": true,
    "singleQuote": true,
    "printWidth": 120,
    "tabWidth": 4,
    "trailingComma": "es5",
    "bracketSpacing": true,
    "vueIndentScriptAndStyle": false,
    "overrides": [
        {
            "files": "*.vue",
            "options": {
                "vueIndentScriptAndStyle": false
            }
        }
    ]
}
